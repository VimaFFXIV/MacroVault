<Project Sdk="Dalamud.NET.Sdk/14.0.2">
  <PropertyGroup>
    <Version>1.1.0.0</Version>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <!-- Resolve to the DALAMUD_HOME env var on CI, or the local XIVLauncher install otherwise -->
    <DalamudLibPath Condition="'$(DALAMUD_HOME)' != ''">$(DALAMUD_HOME)/</DalamudLibPath>
    <DalamudLibPath Condition="'$(DALAMUD_HOME)' == ''">$(LocalAppData)\XIVLauncher\addon\Hooks\dev\</DalamudLibPath>
  </PropertyGroup>
  <ItemGroup>
    <!-- Dalamud replaced ImGui.NET with Dalamud.Bindings.ImGui in v14+.
         Reference it from the Dalamud directory so versions always match. -->
    <Reference Include="Dalamud.Bindings.ImGui">
      <HintPath>$(DalamudLibPath)Dalamud.Bindings.ImGui.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>
</Project>
